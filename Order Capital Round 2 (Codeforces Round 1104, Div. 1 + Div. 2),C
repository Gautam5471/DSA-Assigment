#include <bits/stdc++.h>
using namespace std;
 
int main() {
    int t;
    cin>>t;
    while(t--){
        long long n;
        cin>>n;
        vector<long long>v(n);
        for (int i = 0; i < n; ++i){
            cin>>v[i];
        }
        for(int i=0; i<n-1; i++){
            if(v[i+1]<v[i]){
                v[i+1]+=v[i];
            }
        }
        cout<<v[n-1]<<endl;
    }
 
    return 0;
}
