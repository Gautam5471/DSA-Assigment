#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n,l,r;
        cin>>n>>l>>r;

        vector<int>v(n);
        for(int i=0; i<n; i++){
            cin>>v[i];
        }
        int sum=0;
        int sum2=0;
        for(int i=0; i<l-1; i++){
            sum+=v[i];
        }

        for(int i=r; i<n; i++){
            sum2+=v[i];
        }
        cout<<max(sum,sum2)<<endl;
    }

    return 0;
}
