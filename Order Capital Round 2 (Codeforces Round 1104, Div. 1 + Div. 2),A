#include <bits/stdc++.h>
using namespace std;
 
int main() {
    int t;
    cin>>t;
    while(t--){
        long long n;
        cin>>n;
        vector<long long>v(n);
        for (int i = 0; i < n; ++i){
            cin>>v[i];
        }
        for(int i=0; i<n; i++){
            for(int j=i+1; j<n; j++){
                if(v[j]>v[i])v[j]=v[i];
            }
        }
 
        long long sum=0;
 
        for(int i=0; i<n; i++){
           sum+=v[i];
        }
        cout<<sum<<endl;
    }
 
    return 0;
}
