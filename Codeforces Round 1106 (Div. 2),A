#include <bits/stdc++.h>
using namespace std;
 
void solve(){
     int n , c;
        cin >> n >> c;
        vector <int> a(n); 
        vector<int> b(n);
        for(int i = 0; i < n; i++){
            cin >> a[i];
        }
        for(int i = 0; i < n; i++){
            cin >> b[i];
        }
 
        vector<int> v1 = a;
        vector<int> v2 = b;
        int sum  = 0;
        sort(v1.begin(),v1.end());
        sort(v2.begin(),v2.end());
 
        for(int i = 0; i < n;i++){
            if(v1[i] < v2[i]){
                cout << "-1" << endl;
                return;
            }
        }
        for(int i = 0; i < n ; i++){
            if(a[i] < b[i]){
                sum += c;
                break;
            }
        }
        for(int i = 0; i < n; i++){
            sum += (v1[i] - v2[i]);
        }
        
        cout << sum << endl;
}
 
int main(){
    int t;
    cin >> t;
    while(t--){
        solve();
    }
    return 0;
}
